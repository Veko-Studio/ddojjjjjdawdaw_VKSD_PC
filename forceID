local blockdef = require(game:GetService("ReplicatedStorage").ModuIes.BlockDef)
local buildGUI2 = game:GetService("Players").LocalPlayer.PlayerGui:WaitForChild("BuildGUI2")
local function getBoundingBoxSize(vectors)
    local voxels = vectors
    if #voxels == 0 then return Vector3.new(0,0,0) end
    
    local minX, minY, minZ = voxels[1].X, voxels[1].Y, voxels[1].Z
    local maxX, maxY, maxZ = voxels[1].X, voxels[1].Y, voxels[1].Z
    
    for _, v in ipairs(voxels) do
        if v.X < minX then minX = v.X end
        if v.Y < minY then minY = v.Y end
        if v.Z < minZ then minZ = v.Z end
        
        if v.X > maxX then maxX = v.X end
        if v.Y > maxY then maxY = v.Y end
        if v.Z > maxZ then maxZ = v.Z end
    end
    
    local sizeX = maxX - minX + 1
    local sizeY = maxY - minY + 1
    local sizeZ = maxZ - minZ + 1
    
    return Vector3.new(sizeX, sizeY, sizeZ)
end
local function selectBlock(id)
    game:GetService("Players").LocalPlayer.PlayerGui.BuildGui.EnableBuilding:Fire()
    if workspace.Camera.BuildObjects:FindFirstChildOfClass("Model").ID.Value ~= id then
        game:GetService("Players").LocalPlayer.PlayerGui.BuildGui.EnableBuilding:Fire()
        buildGUI2.Bindables.CategoryPressed:Fire(blockdef[id].Category)
        task.wait(0.1)
        buildGUI2.Bindables.BlockSelected:Fire(id)
        buildGUI2.Bindables.BlockSelected2:Fire(id)
        task.wait(0.01)
        if workspace.Camera.BuildObjects:FindFirstChildOfClass("Model").ID.Value ~= id then
            local size = getBoundingBoxSize(blockdef[id].VoxelsUsed);print("3",size)
            game:GetService("Players").LocalPlayer.PlayerGui.BuildGUI2.Bindables.SizeSelected:Fire(size)
        end
        task.wait(0.1)
    end
end
getfenv().forceID = selectBlock
